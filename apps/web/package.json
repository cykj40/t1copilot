{
  "name": "@t1copilot/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:safety": "vitest run src/__tests__/safety",
    "eval": "pnpm eval:routing && pnpm eval:behavior && pnpm eval:safety && pnpm eval:quality",
    "eval:routing": "dotenv -e ../../.env -- tsx --conditions=react-server evals/routing.eval.ts",
    "eval:behavior": "dotenv -e ../../.env -- tsx --conditions=react-server evals/behavior.eval.ts",
    "eval:safety": "dotenv -e ../../.env -- tsx --conditions=react-server evals/safety.eval.ts",
    "eval:quality": "dotenv -e ../../.env -- tsx --conditions=react-server evals/quality.eval.ts",
    "eval:validate": "tsx --conditions=react-server evals/validate-datasets.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/react": "^3.0.186",
    "@base-ui/react": "^1.4.1",
    "@t1copilot/db": "workspace:*",
    "@t1copilot/mcp-clients": "workspace:*",
    "@t1copilot/types": "workspace:*",
    "@t1copilot/utils": "workspace:*",
    "ai": "^6.0.184",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "lucide-react": "^1.16.0",
    "next": "15.3.1",
    "openai": "^6.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "server-only": "0.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoevals": "^0.3.0",
    "braintrust": "^3.20.0",
    "dotenv-cli": "^11.0.0",
    "happy-dom": "^20.10.3",
    "msw": "^2.14.6",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  }
}
