# ── Dexcom CGM ──────────────────────────────────────────────
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_REDIRECT_URI=http://localhost:3000/api/auth/dexcom/callback
# Sandbox: https://sandbox-api.dexcom.com  |  Prod: https://api.dexcom.com
DEXCOM_BASE_URL=https://sandbox-api.dexcom.com
DEXCOM_MCP_SERVER_URL=https://dexcom-mcp-server.fly.dev
DEXCOM_MCP_AUTH_TOKEN=

# ── Peloton MCP ─────────────────────────────────────────────
PELOTON_MCP_SERVER_URL=https://peloton-mcp-server.fly.dev
PELOTON_MCP_AUTH_TOKEN=

# ── Peloton ─────────────────────────────────────────────────
PELOTON_USERNAME=
PELOTON_PASSWORD=

# ── Database — Turso (SQLite edge) ──────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# ── Database — Neon (Postgres + PGVector) ───────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/t1copilot?sslmode=require

# ── Self-hosted single user ──────────────────────────────────────────────────
SYSTEM_USER_ID=

# ── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Next.js / App ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Apple Health (iOS Shortcut webhook) ─────────────────────
APPLE_HEALTH_WEBHOOK_SECRET=
